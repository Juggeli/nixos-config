{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"files": {
		"includes": ["packages/*/extensions/**/*.ts", "packages/*/__tests__/**/*.ts"]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
